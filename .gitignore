dist/
build/

# ── Frontend ─────────────────────────────────────────────────────────────
/frontend/node_modules/
/frontend/dist/
/frontend/.next/
/frontend/tsconfig.tsbuildinfo

# ── Root node_modules (should never exist here) ──────────────────────────
/node_modules/
/package-lock.json
/package.json

# ── AutoForze binary (built on target) ───────────────────────────────────
/autoforze/bin/
/bin/

# ── Runtime / cache junk ─────────────────────────────────────────────────
/.wwebjs_auth/
/.wwebjs_cache/
/.playwright-mcp/
*.log
*.pid

# ── Skill library (not project source) ───────────────────────────────────
/skills/

